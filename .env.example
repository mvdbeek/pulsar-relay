# Pulsar Relay Environment Variables
# Copy this file to .env and customize for your deployment
#
# Configuration precedence (highest to lowest):
# 1. Environment variables (this file or system env vars) - HIGHEST
# 2. Config file (config.toml or config.yaml)
# 3. Default values - LOWEST

# Note: All variables are prefixed with PULSAR_
# Example: PULSAR_STORAGE_BACKEND=valkey
#
# Note: HTTP port and workers are controlled by uvicorn at startup:
#   uvicorn pulsar_relay.main:app --host 0.0.0.0 --port 8080 --workers 4

# ============================================================================
# Server Configuration
# ============================================================================
# PULSAR_APP_NAME="Pulsar Relay"

# ============================================================================
# Storage Backend
# ============================================================================
# PULSAR_STORAGE_BACKEND=memory  # Options: memory, valkey

# ============================================================================
# Valkey Configuration
# ============================================================================
# PULSAR_VALKEY_HOST=localhost
# PULSAR_VALKEY_PORT=6379
# PULSAR_VALKEY_USE_TLS=false
# PULSAR_VALKEY_USERNAME=                    # ACL username; omit for legacy AUTH
# PULSAR_VALKEY_PASSWORD=                    # REQUIRED when backend=valkey
# PULSAR_VALKEY_CA_PATH=                     # CA bundle path; only used when USE_TLS=true

# ============================================================================
# Storage Configuration
# ============================================================================
# PULSAR_PERSISTENT_TIER_RETENTION=86400
# PULSAR_MAX_MESSAGES_PER_TOPIC=1000000

# ============================================================================
# Logging
# ============================================================================
# PULSAR_LOG_LEVEL=INFO  # Options: DEBUG, INFO, WARNING, ERROR, CRITICAL

# ============================================================================
# Error Reporting (Sentry — optional)
# ============================================================================
# Requires the optional extra: pip install pulsar-relay[sentry]
# Reporting is active only when PULSAR_SENTRY_DSN is set; otherwise it's a no-op.
# PULSAR_SENTRY_DSN=                          # Sentry DSN; unset = disabled
# PULSAR_SENTRY_ENVIRONMENT=production        # Environment tag on events
# PULSAR_SENTRY_TRACES_SAMPLE_RATE=0.0        # 0.0 = errors only (default)
# PULSAR_SENTRY_SEND_DEFAULT_PII=false        # Send client IP/headers to Sentry

# ============================================================================
# HTTP transport (REQUIRED in production)
# ============================================================================
# JSON-encoded lists. Both are REQUIRED — the startup guard refuses to
# boot with either left empty (unless PULSAR_ALLOW_INSECURE_DEFAULTS=1).
# PULSAR_ALLOWED_ORIGINS='["https://relay.example.com"]'
# PULSAR_TRUSTED_HOSTS='["relay.example.com"]'
# PULSAR_WS_MAX_PER_USER=10
# PULSAR_WS_IDLE_SECONDS=60
# PULSAR_MAX_BODY_BYTES=1048576

# ============================================================================
# Authentication (REQUIRED)
# ============================================================================
# Generate a strong (32+ char) secret. The relay refuses to start without one.
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# PULSAR_JWT_SECRET_KEY=                     # REQUIRED (>= 32 chars, no default)
# PULSAR_BOOTSTRAP_ADMIN_USERNAME=admin
# PULSAR_BOOTSTRAP_ADMIN_PASSWORD=           # REQUIRED
# PULSAR_BOOTSTRAP_ADMIN_EMAIL=admin@example.com
#
# Escape hatch for local-dev / tests ONLY. The local-dev compose sets this;
# production deployments must leave it unset.
# PULSAR_ALLOW_INSECURE_DEFAULTS=1

# ============================================================================
# Config File Path (optional)
# ============================================================================
# Specify custom config file location
# PULSAR_CONFIG_FILE=/path/to/config.toml

# ============================================================================
# Example Production Configuration
# ============================================================================
# PULSAR_APP_NAME="Pulsar Relay Production"
# PULSAR_STORAGE_BACKEND=valkey
# PULSAR_VALKEY_HOST=valkey.example.com
# PULSAR_VALKEY_PORT=6379
# PULSAR_VALKEY_USE_TLS=true
# PULSAR_VALKEY_PASSWORD=REPLACE_WITH_VALKEY_PASSWORD
# PULSAR_LOG_LEVEL=WARNING
# PULSAR_JWT_SECRET_KEY=REPLACE_WITH_SECURE_RANDOM_KEY
# PULSAR_BOOTSTRAP_ADMIN_PASSWORD=REPLACE_WITH_STRONG_ADMIN_PASSWORD
